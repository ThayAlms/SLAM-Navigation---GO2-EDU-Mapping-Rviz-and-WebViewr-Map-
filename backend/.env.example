APP_ENV=development
APP_NAME="XD4 Robotics API"
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173

# Project URL e chave publicável/anon do Supabase.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA

# Somente no backend. Nunca use esta chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_SUBSTITUA

# Segredo compartilhado com o futuro bridge executado na Jetson.
INTEGRATION_API_KEY=gere-um-segredo-longo-e-aleatorio

# Integração direta com o gateway ROS executado na mesma Jetson.
# Deixe vazio para usar somente a fila Supabase/4G.
ROBOT_GATEWAY_URL=http://127.0.0.1:8081
ROBOT_GATEWAY_API_KEY=gere-outra-chave-longa-e-aleatoria
ROBOT_GATEWAY_TIMEOUT_SECONDS=3

# Integração Oracle futura.
ORACLE_API_URL=
ORACLE_API_KEY=
